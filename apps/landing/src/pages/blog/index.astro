---
import { getCollection, } from "astro:content";

const posts = await getCollection("blog");
posts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Notes from the team | Philo</title>
    <meta
      name="description"
      content="Product notes from the Philo team on daily planning, recurring systems, and disposable widgets."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="ambient"></div>
    <main class="shell">
      <header class="page-header">
        <a class="back-link" href="/">← Back to Philo</a>
        <p class="eyebrow">Blog</p>
        <h1>Notes from the team</h1>
      </header>

      <section class="panel">
        <ul class="post-list">
          {
            posts.map((post,) => (
              <li>
                <a href={`/blog/${post.slug}`}>
                  <div class="post-copy">
                    <p class="post-title">{post.data.title}</p>
                    <p class="post-summary">{post.data.summary}</p>
                  </div>
                  <p class="post-date">
                    {post.data.publishedAt.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    },)}
                  </p>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <footer class="footer">
        <nav>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="https://github.com/ComputelessComputer/philo">GitHub</a>
          <a href="mailto:john@hyprnote.com">Email</a>
        </nav>
      </footer>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f4f4f1;
    --bg-soft: #f8f8f6;
    --line: #e2e2db;
    --text: #252525;
    --muted: #646460;
    --accent: #5f70d8;
    --fs-xs: 11px;
    --fs-sm: 12px;
    --fs-md: 13px;
    --fs-lg: 14px;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: "IBM Plex Mono", "SFMono-Regular", Menlo, monospace;
    font-weight: 400;
    font-size: var(--fs-md);
    line-height: 1.6;
    background: linear-gradient(150deg, #f6f6f4 0%, #efefeb 100%);
    color: var(--text);
    position: relative;
  }

  .ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 5% 8%, #ffffff 0%, transparent 32%),
      radial-gradient(circle at 92% 92%, #e8ebff 0%, transparent 38%);
    opacity: 0.8;
  }

  .shell {
    position: relative;
    width: min(100%, 760px);
    margin: 0 auto;
    padding: 56px 24px 88px;
  }

  .page-header {
    border-bottom: 1px solid var(--line);
    padding-bottom: 18px;
  }

  .back-link {
    color: var(--accent);
    text-decoration: none;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .eyebrow {
    margin: 20px 0 0;
    color: #3f3f3d;
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h1 {
    margin: 12px 0 0;
    font-size: var(--fs-lg);
    font-weight: 500;
    line-height: 1.6;
  }

  .panel {
    margin-top: 22px;
  }

  .footer {
    margin-top: 32px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }

  .footer nav {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer a {
    color: var(--accent);
    text-decoration: none;
  }

  .footer a:hover {
    text-decoration: underline;
  }

  .post-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .post-list li {
    border-bottom: 1px dashed #e9e9e2;
  }

  .post-list a {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 16px;
    padding: 12px 0;
    text-decoration: none;
    color: var(--text);
    align-items: start;
  }

  .post-title {
    margin: 0;
    font-size: var(--fs-md);
    font-weight: 500;
    color: var(--text);
  }

  .post-summary {
    margin: 5px 0 0;
    font-size: var(--fs-md);
    color: var(--muted);
  }

  .post-date {
    margin: 0;
    font-size: var(--fs-sm);
    color: color-mix(in srgb, var(--muted) 92%, var(--accent));
    white-space: nowrap;
    padding-top: 1px;
  }

  .post-list a:hover .post-title {
    color: color-mix(in srgb, var(--text) 80%, var(--accent));
  }

  @media (max-width: 720px) {
    .shell {
      padding: 40px 18px 62px;
    }

    .post-list a {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }
</style>
