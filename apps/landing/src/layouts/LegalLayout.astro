---
interface Props {
  title: string;
  description: string;
  effectiveDate: string;
}

const { title, description, effectiveDate, } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Philo</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="ambient"></div>
    <main class="shell">
      <header class="page-header">
        <a class="back-link" href="/">← Back to Philo</a>
        <p class="label">Legal</p>
        <h1>{title}</h1>
        <p class="summary">{description}</p>
        <p class="meta">Effective date: {effectiveDate}</p>
      </header>

      <article class="content">
        <slot />
      </article>

      <footer class="footer">
        <nav>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="https://github.com/ComputelessComputer/philo">GitHub</a>
          <a href="mailto:john@hyprnote.com">Email</a>
        </nav>
      </footer>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f4f4f1;
    --bg-soft: #f8f8f6;
    --line: #e2e2db;
    --text: #252525;
    --muted: #646460;
    --accent: #5f70d8;
    --fs-xs: 11px;
    --fs-sm: 12px;
    --fs-md: 13px;
    --fs-lg: 14px;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: "IBM Plex Mono", "SFMono-Regular", Menlo, monospace;
    font-weight: 400;
    font-size: var(--fs-md);
    line-height: 1.6;
    background: linear-gradient(150deg, #f6f6f4 0%, #efefeb 100%);
    color: var(--text);
    position: relative;
  }

  .ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 5% 8%, #ffffff 0%, transparent 32%),
      radial-gradient(circle at 92% 92%, #e8ebff 0%, transparent 38%);
    opacity: 0.8;
  }

  .shell {
    position: relative;
    width: min(100%, 760px);
    margin: 0 auto;
    padding: 56px 24px 88px;
  }

  .page-header {
    border-bottom: 1px solid var(--line);
    padding-bottom: 18px;
  }

  .back-link {
    color: var(--accent);
    text-decoration: none;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .label {
    margin: 20px 0 0;
    color: #3f3f3d;
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h1 {
    margin: 12px 0 0;
    font-size: var(--fs-lg);
    font-weight: 500;
    line-height: 1.6;
  }

  .summary {
    margin: 10px 0 0;
    color: #3f3f3d;
    font-size: var(--fs-md);
  }

  .meta {
    margin: 8px 0 0;
    color: #6b6b66;
    font-size: var(--fs-sm);
  }

  .content {
    margin-top: 22px;
    color: var(--muted);
  }

  .content :global(h2) {
    margin: 24px 0 6px;
    color: var(--text);
    font-size: var(--fs-md);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .content :global(p) {
    margin: 10px 0;
    color: var(--muted);
    font-size: var(--fs-md);
    line-height: 1.7;
  }

  .content :global(ul),
  .content :global(ol) {
    margin: 10px 0;
    padding-left: 18px;
  }

  .content :global(ol) {
    list-style: none;
    counter-reset: ol-counter;
    padding-left: 0;
  }

  .content :global(ol) > :global(li) {
    counter-increment: ol-counter;
  }

  .content :global(ol) > :global(li)::before {
    content: counter(ol-counter) ".\00a0";
  }

  .content :global(li) {
    margin: 6px 0;
    font-size: var(--fs-md);
    color: var(--muted);
  }

  .content :global(a),
  .footer a {
    color: var(--accent);
    text-decoration: none;
  }

  .content :global(a:hover),
  .footer a:hover {
    text-decoration: underline;
  }

  .content :global(code) {
    background: color-mix(in srgb, var(--bg-soft) 80%, #ffffff);
    border: 1px solid var(--line);
    padding: 1px 4px;
    font-size: var(--fs-sm);
  }

  .footer {
    margin-top: 32px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }

  .footer nav {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  @media (max-width: 720px) {
    .shell {
      padding: 40px 18px 62px;
    }
  }
</style>
