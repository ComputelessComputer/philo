{
  "name": "philo-workspace",
  "private": true,
  "version": "0.0.10",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/desktop dev",
    "build": "bun run --cwd apps/desktop build",
    "preview": "bun run --cwd apps/desktop preview",
    "typecheck": "bun run --cwd apps/desktop typecheck",
    "fmt": "dprint fmt",
    "fmt:check": "dprint check",
    "check": "bun run typecheck && bun run fmt",
    "tauri": "node apps/desktop/scripts/tauri.mjs"
  }
}
